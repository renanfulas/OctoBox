[Unit]
Description=OctoBOX Signal Mesh retry sweep
After=network-online.target octobox-gunicorn.service
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/srv/octobox/app
EnvironmentFile=-/srv/octobox/shared/octobox.env
ExecStart=/srv/octobox/app/.venv/bin/python manage.py run_signal_mesh_retry_sweep --job-limit 25 --webhook-limit 25
User=root

[Install]
WantedBy=multi-user.target
