## ARQUIVO: exemplo de variaveis de ambiente do projeto.
##
## POR QUE ELE EXISTE:
## - Mostra o conjunto minimo de configuracoes para desenvolvimento e homologacao/producao.
##
## O QUE ESTE ARQUIVO FAZ:
## 1. Explica como selecionar o ambiente.
## 2. Lista variaveis de seguranca, hosts e HTTPS.
## 3. Mostra o formato esperado para DATABASE_URL e REDIS_URL.
## 4. Resume o contrato minimo para uma VPS Linux em producao.
##
## PONTOS CRITICOS:
## - Este arquivo e apenas um exemplo e nao deve conter segredos reais.
## - Em producao, DJANGO_SECRET_KEY e DATABASE_URL precisam vir do ambiente real.

DJANGO_ENV=development
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=REQUIRED-GENERATE-SECURE-KEY-FOR-PROD
PHONE_BLIND_INDEX_KEY=REQUIRED-GENERATE-SECURE-BLIND-INDEX-KEY-FOR-PROD
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Em desenvolvimento, o projeto tambem aceita automaticamente hostname local e IPs privados da maquina.
# Para expor o servidor na rede, use a task "Run Django Server (LAN)" ou rode:
# python manage.py runserver 0.0.0.0:8000

# Exemplo local com SQLite automatico:
# deixe DATABASE_URL vazio para usar db.sqlite3

# Exemplo para homologacao/producao com PostgreSQL:
# DATABASE_URL=postgresql://postgres:senha@localhost:5432/octobox_control
# DB_CONN_MAX_AGE=60
# DB_SSL_REQUIRE=True

# Cache compartilhada opcional para homologacao/producao.
# Se ficar vazio, o projeto usa cache local em memoria.
# BOX_RUNTIME_SLUG deve identificar o runtime do box piloto ou da celula atual.
# Exemplo: BOX_RUNTIME_SLUG=box-piloto-vila-mar
# O prefixo real do cache vira automaticamente CACHE_KEY_PREFIX:BOX_RUNTIME_SLUG.
BOX_RUNTIME_SLUG=control
# Habilite o workspace quente do manager no piloto quando a Fase 1 exigir esse papel.
# OPERATIONS_MANAGER_WORKSPACE_ENABLED=True
OPERATIONS_MANAGER_WORKSPACE_ENABLED=False
# REDIS_URL=redis://usuario:senha@host:6379/0
# CACHE_IGNORE_EXCEPTIONS=True
# CACHE_KEY_PREFIX=octobox
REDIS_URL=
CACHE_IGNORE_EXCEPTIONS=True
CACHE_KEY_PREFIX=octobox
STUDENT_APP_SESSION_COOKIE_NAME=octobox_student_session
STUDENT_APP_SESSION_COOKIE_AGE=604800
STUDENT_OAUTH_PUBLIC_BASE_URL=
STUDENT_GOOGLE_OAUTH_CLIENT_ID=
STUDENT_GOOGLE_OAUTH_CLIENT_SECRET=
STUDENT_APPLE_OAUTH_CLIENT_ID=
STUDENT_APPLE_OAUTH_TEAM_ID=
STUDENT_APPLE_OAUTH_KEY_ID=
STUDENT_APPLE_OAUTH_PRIVATE_KEY=
STUDENT_EMAIL_PROVIDER=smtp
STUDENT_EMAIL_FROM=
STUDENT_RESEND_API_KEY=
STUDENT_RESEND_WEBHOOK_SECRET=
STUDENT_INVITE_LANDING_RATE_LIMIT_MAX_REQUESTS=20
STUDENT_INVITE_LANDING_RATE_LIMIT_WINDOW_SECONDS=300
STUDENT_OAUTH_CALLBACK_RATE_LIMIT_MAX_REQUESTS=12
STUDENT_OAUTH_CALLBACK_RATE_LIMIT_WINDOW_SECONDS=300
STUDENT_OPEN_BOX_INVITE_WINDOW_HOURS=24
STUDENT_OPEN_BOX_INVITE_LIMIT_PER_WINDOW=25
STUDENT_INVITE_CREATION_ACTOR_ALERT_WINDOW_SECONDS=900
STUDENT_INVITE_CREATION_ACTOR_ALERT_THRESHOLD=12
STUDENT_INVITE_CREATION_BOX_ALERT_WINDOW_SECONDS=900
STUDENT_INVITE_CREATION_BOX_ALERT_THRESHOLD=20
STUDENT_INVITE_ACCEPT_IP_ALERT_WINDOW_SECONDS=600
STUDENT_INVITE_ACCEPT_IP_ALERT_THRESHOLD=8
STUDENT_INVITE_ACCEPT_BOX_ALERT_WINDOW_SECONDS=600
STUDENT_INVITE_ACCEPT_BOX_ALERT_THRESHOLD=12

DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

# Caminho interno do admin em producao.
# Troque por um valor nao obvio e mantenha fora de canais publicos.
DJANGO_ADMIN_URL_PATH=painel-interno-privado

# Opcional para monitoramento de producao.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# Baseline de throttle por escopo.
LOGIN_RATE_LIMIT_MAX_REQUESTS=8
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
ADMIN_RATE_LIMIT_MAX_REQUESTS=12
ADMIN_RATE_LIMIT_WINDOW_SECONDS=300
WRITE_RATE_LIMIT_MAX_REQUESTS=30
WRITE_RATE_LIMIT_WINDOW_SECONDS=60
EXPORT_RATE_LIMIT_MAX_REQUESTS=6
EXPORT_RATE_LIMIT_WINDOW_SECONDS=300
DASHBOARD_RATE_LIMIT_MAX_REQUESTS=30
DASHBOARD_RATE_LIMIT_WINDOW_SECONDS=60
HEAVY_READ_RATE_LIMIT_MAX_REQUESTS=30
HEAVY_READ_RATE_LIMIT_WINDOW_SECONDS=60
AUTOCOMPLETE_RATE_LIMIT_MAX_REQUESTS=60
AUTOCOMPLETE_RATE_LIMIT_WINDOW_SECONDS=60

# Preencha apenas com os proxies reais que encaminham o IP do cliente.
# Exemplo: SECURITY_TRUSTED_PROXY_IPS=203.0.113.10,203.0.113.11
SECURITY_TRUSTED_PROXY_IPS=

# O blocklist inicial deve nascer vazio ate haver evidencia operacional.
SECURITY_BLOCKED_IPS=
SECURITY_BLOCKED_IP_RANGES=
SECURITY_LOG_LEVEL=WARNING

# Exemplo de producao em VPS Linux com PostgreSQL e Redis locais:
# DJANGO_ENV=production
# DJANGO_DEBUG=False
# DJANGO_SECRET_KEY=gere-um-segredo-forte
# PHONE_BLIND_INDEX_KEY=gere-uma-chave-forte-separada
# DJANGO_ALLOWED_HOSTS=app.seudominio.com
# DATABASE_URL=postgresql://octobox_app:senha-forte@127.0.0.1:5432/octobox_control
# REDIS_URL=redis://127.0.0.1:6379/0
# BOX_RUNTIME_SLUG=box-piloto-vila-mar
# DJANGO_ADMIN_URL_PATH=painel-interno-privado-longo
