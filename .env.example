## ARQUIVO: exemplo de variaveis de ambiente do projeto.
##
## POR QUE ELE EXISTE:
## - Mostra o conjunto minimo de configuracoes para desenvolvimento e homologacao/producao.
##
## O QUE ESTE ARQUIVO FAZ:
## 1. Explica como selecionar o ambiente.
## 2. Lista variaveis de seguranca, hosts e HTTPS.
## 3. Mostra o formato esperado para DATABASE_URL.
##
## PONTOS CRITICOS:
## - Este arquivo e apenas um exemplo e nao deve conter segredos reais.
## - Em producao, DJANGO_SECRET_KEY e DATABASE_URL precisam vir do ambiente real.

DJANGO_ENV=development
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=troque-esta-chave-em-producao
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Exemplo local com SQLite automatico:
# deixe DATABASE_URL vazio para usar db.sqlite3

# Exemplo para homologacao/producao com PostgreSQL:
# DATABASE_URL=postgresql://postgres:senha@localhost:5432/octobox_control
# DB_SSL_REQUIRE=True

DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
